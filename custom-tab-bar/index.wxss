.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 112rpx;
  background: #F5EFE6;
  border-top: 1rpx solid #EDE5D8;
  display: flex;
  align-items: flex-end;
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 999;
}

.tab-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 112rpx;
}

.tab-item-center {
  position: relative;
}

/* 中间定制按钮 */
.tab-center-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  top: -24rpx;
}

.tab-center-btn {
  width: 88rpx;
  height: 88rpx;
  background: #2C1A0E;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 20rpx rgba(44,26,14,0.30);
  margin-bottom: 6rpx;
}

.tab-center-plus {
  color: #F5EFE6;
  font-size: 48rpx;
  font-weight: 200;
  line-height: 1;
  margin-top: -4rpx;
}

.tab-center-label {
  font-size: 20rpx;
  color: #9C8672;
}

/* 普通 tab */
.tab-normal {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  padding-bottom: 10rpx;
}

.tab-icon-wrap {
  position: relative;
  width: 48rpx;
  height: 48rpx;
}

.tab-icon {
  width: 48rpx;
  height: 48rpx;
}

/* 购物车角标 */
.cart-badge {
  position: absolute;
  top: -10rpx;
  right: -18rpx;
  background: #C87941;
  border-radius: 24rpx;
  min-width: 32rpx;
  height: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
  border: 2rpx solid #F5EFE6;
}
.cart-badge-text {
  font-size: 18rpx;
  color: #FFFFFF;
  font-weight: 700;
  line-height: 1;
}

.tab-label {
  font-size: 20rpx;
  color: #9C8672;
}

.tab-label-active {
  font-size: 20rpx;
  color: #2C1A0E;
  font-weight: 500;
}
