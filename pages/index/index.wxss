page {
  background: #F5EFE6;
  height: 100%;
}

.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #F5EFE6;
}

/* ── 顶部 ── */
.header {
  background: #F5EFE6;
  padding: 20rpx 32rpx 0;
  flex-shrink: 0;
}

.header-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.logo-en {
  display: block;
  font-size: 38rpx;
  font-weight: 700;
  color: #2C1A0E;
  letter-spacing: 1rpx;
}

.logo-cn {
  display: block;
  font-size: 22rpx;
  color: #9C8672;
  margin-top: 2rpx;
}

.search-bar {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  border-radius: 40rpx;
  padding: 10rpx 22rpx;
  margin-bottom: 12rpx;
  box-shadow: 0 1rpx 8rpx rgba(44,26,14,0.06);
}

.search-icon-img {
  width: 28rpx;
  height: 28rpx;
  margin-right: 10rpx;
  opacity: 0.6;
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  font-size: 26rpx;
  color: #2C1A0E;
  height: 56rpx;
  line-height: 56rpx;
}

.search-placeholder {
  color: #C0B8AE;
}

/* ── 滚动区 ── */
.scroll-body {
  flex: 1;
  overflow: hidden;
}

/* ── Banner 分栏布局 ── */
.banner-swiper {
  height: 320rpx;
  margin: 0 32rpx 24rpx;
  border-radius: 28rpx;
  overflow: hidden;
}

.banner-item {
  width: 100%;
  height: 320rpx;
  display: flex;
  align-items: stretch;
  overflow: hidden;
}

.banner-text-side {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 36rpx 28rpx 36rpx 36rpx;
  z-index: 2;
}

.banner-main-title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #2C1A0E;
  line-height: 1.3;
  margin-bottom: 10rpx;
  letter-spacing: -0.5rpx;
}

.banner-subtitle {
  display: block;
  font-size: 22rpx;
  color: #9C8672;
  margin-bottom: 24rpx;
  line-height: 1.5;
}

.banner-action-btn {
  display: inline-flex;
  align-items: center;
  background: #2C1A0E;
  border-radius: 48rpx;
  padding: 14rpx 28rpx;
  align-self: flex-start;
}

.banner-btn-text {
  color: #F5EFE6;
  font-size: 24rpx;
  font-weight: 500;
  letter-spacing: 0.3rpx;
}

.banner-img-side {
  width: 220rpx;
  flex-shrink: 0;
  overflow: hidden;
}

.banner-slide-img {
  width: 220rpx;
  height: 320rpx;
  display: block;
}

/* ── 分类快捷入口 ── */
.cat-grid {
  display: flex;
  justify-content: space-around;
  padding: 8rpx 16rpx 24rpx;
}

.cat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  flex: 1;
}

.cat-icon-wrap {
  width: 96rpx;
  height: 96rpx;
  background: #FFFFFF;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 12rpx rgba(44,26,14,0.07);
}

.cat-icon-svg {
  width: 48rpx;
  height: 48rpx;
  display: block;
}

.cat-name {
  font-size: 20rpx;
  color: #9C8672;
  text-align: center;
  white-space: nowrap;
}

/* ── 区块标题 ── */
.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 8rpx 32rpx 20rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #2C1A0E;
}

.section-more {
  font-size: 26rpx;
  color: #9C8672;
}

/* ── 新人专享 ── */
.section-title-wrap {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
}

.section-title-dot {
  font-size: 28rpx;
  color: #C4A882;
  font-weight: 400;
}

.section-title-sub {
  font-size: 28rpx;
  font-weight: 500;
  color: #9C8672;
}

.newbie-scroll {
  width: 100%;
}

.newbie-list {
  display: flex;
  padding: 0 32rpx 24rpx;
  gap: 16rpx;
  width: max-content;
}

.newbie-card {
  width: 200rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 14rpx rgba(44,26,14,0.08);
  flex-shrink: 0;
}

.newbie-img-wrap {
  width: 200rpx;
  height: 200rpx;
  background: #F0EAE0;
  overflow: hidden;
  position: relative;
}

.newbie-img {
  width: 200rpx;
  height: 200rpx;
  display: block;
}

.newbie-badge {
  position: absolute;
  top: 12rpx;
  left: 12rpx;
  background: linear-gradient(135deg, #C87941, #E8A870);
  color: #FFFFFF;
  font-size: 18rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-weight: 500;
}

.newbie-info {
  padding: 14rpx 14rpx 16rpx;
  display: flex;
  flex-direction: column;
}

.newbie-name {
  font-size: 24rpx;
  color: #2C1A0E;
  font-weight: 500;
  display: block;
  margin-bottom: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.newbie-desc {
  font-size: 19rpx;
  color: #B0A090;
  display: block;
  margin-bottom: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.newbie-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.newbie-price-wrap {
  display: flex;
  align-items: baseline;
  gap: 1rpx;
}

.newbie-price-symbol {
  font-size: 18rpx;
  color: #C87941;
  font-weight: 600;
}

.newbie-price {
  font-size: 30rpx;
  font-weight: 700;
  color: #C87941;
}

/* ── 精选横向滚动 ── */
.h-scroll {
  width: 100%;
}

.h-list {
  display: flex;
  padding: 0 32rpx 24rpx;
  gap: 20rpx;
  width: max-content;
}

.h-card {
  width: 240rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 16rpx rgba(44,26,14,0.08);
  flex-shrink: 0;
}

.h-img-wrap {
  width: 240rpx;
  height: 240rpx;
  background: #EDE5D8;
  overflow: hidden;
  position: relative;
}

.h-img {
  width: 240rpx;
  height: 240rpx;
  display: block;
}

/* 透明心形收藏按钮（无背景） */
.card-fav {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  width: 52rpx;
  height: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: transparent;
  z-index: 2;
}

.card-fav-icon {
  font-size: 36rpx;
  color: rgba(255,255,255,0.9);
  text-shadow: 0 1rpx 6rpx rgba(0,0,0,0.35);
  line-height: 1;
  transition: color 0.2s;
  font-family: 'PingFang SC', 'Helvetica Neue', Arial, sans-serif;
}

.card-fav-active .card-fav-icon {
  color: #8B6A4A;
  text-shadow: 0 1rpx 4rpx rgba(0,0,0,0.2);
}

.h-info {
  padding: 16rpx 16rpx 18rpx;
  display: flex;
  flex-direction: column;
}

.h-name {
  font-size: 24rpx;
  color: #2C1A0E;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-weight: 500;
  display: block;
}

/* tags 标签行 */
.h-tags {
  display: flex;
  gap: 6rpx;
  margin-bottom: 14rpx;
  flex-wrap: wrap;
}

.h-tag {
  font-size: 18rpx;
  color: #9C8672;
  background: #EDE5D8;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.h-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.h-price-wrap {
  display: flex;
  align-items: baseline;
  gap: 2rpx;
}

.h-price {
  font-size: 28rpx;
  font-weight: 700;
  color: #6B4F35;
}

.h-price-unit {
  font-size: 20rpx;
  color: #9C8672;
  font-weight: 400;
}

.add-btn {
  width: 48rpx;
  height: 48rpx;
  background: #EDE5D8;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  border: 1rpx solid #D5CAB8;
}

.add-btn-text {
  color: #2C1A0E;
  font-size: 34rpx;
  line-height: 1;
  margin-top: -2rpx;
}

/* ── 新品 2 列网格 ── */
.grid-2 {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  padding: 0 32rpx;
}

.grid-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 16rpx rgba(44,26,14,0.07);
}

.grid-img-wrap {
  position: relative;
  width: 100%;
  height: 220rpx;
  background: #EDE5D8;
  overflow: hidden;
}

.grid-img {
  width: 100%;
  height: 220rpx;
  display: block;
}

.new-badge {
  position: absolute;
  top: 14rpx;
  left: 14rpx;
  background: #2C1A0E;
  color: #F5EFE6;
  font-size: 20rpx;
  padding: 5rpx 14rpx;
  border-radius: 8rpx;
}

.grid-info {
  padding: 14rpx 16rpx 16rpx;
}

.grid-name {
  display: block;
  font-size: 24rpx;
  color: #2C1A0E;
  margin-bottom: 10rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-weight: 500;
}

.grid-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.grid-price {
  font-size: 28rpx;
  font-weight: 700;
  color: #6B4F35;
}

.add-btn-sm {
  width: 48rpx;
  height: 48rpx;
  background: #2C1A0E;
  border-radius: 50%;
  text-align: center;
  line-height: 48rpx;
  color: #F5EFE6;
  font-size: 32rpx;
  flex-shrink: 0;
}

.page-bottom {
  height: 200rpx;
}

/* ── 大家都在做 ── */
.section-title-wrap { display: flex; align-items: center; }
.section-more { font-size: 24rpx; color: #C87941; }
.grass-scroll { }
.grass-list { display: flex; gap: 20rpx; padding-left: 32rpx; padding-right: 32rpx; }
.grass-card {
  width: 220rpx; flex-shrink: 0;
  background: #FFFFFF; border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 10rpx rgba(44,26,14,0.07);
}
.grass-img-wrap { position: relative; width: 220rpx; height: 293rpx; }
.grass-img { width: 220rpx; height: 293rpx; display: block; }
.grass-avatar-circle {
  position: absolute; top: 12rpx; left: 12rpx;
  width: 44rpx; height: 44rpx; border-radius: 50%;
  background: rgba(245,239,230,0.92);
  display: flex; align-items: center; justify-content: center;
  font-size: 20rpx; border: 2rpx solid #FFFFFF;
}
.grass-info { padding: 14rpx 16rpx 18rpx; }
.grass-username { display: block; font-size: 22rpx; color: #C87941; margin-bottom: 6rpx; }
.grass-title-text {
  display: block; font-size: 24rpx; color: #2C1A0E; font-weight: 500;
  line-height: 1.4; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
}
