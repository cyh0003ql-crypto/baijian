page { background: #F0ECE6; height: 100%; }
.page { height: 100vh; background: #F0ECE6; }
.page-title { font-size: 32rpx; font-weight: 600; color: #3A332D; padding: 24rpx 24rpx 0; }

/* ── 卡片通用 ── */
.section-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  margin: 16rpx 24rpx 0;
  padding: 24rpx;
  box-shadow: 0 2rpx 10rpx rgba(58,51,45,0.05);
}

.section-hd { margin-bottom: 16rpx; }
.section-label { font-size: 26rpx; font-weight: 600; color: #3A332D; }
.section-arrow { font-size: 32rpx; color: #C0B8AE; margin-left: auto; }

/* ── 地址 ── */
.addr-card { display: flex; align-items: center; }
.addr-top { display: flex; align-items: center; gap: 16rpx; margin-bottom: 8rpx; }
.addr-name { font-size: 30rpx; font-weight: 600; color: #3A332D; }
.addr-phone { font-size: 26rpx; color: #8B7961; }
.addr-detail { font-size: 26rpx; color: #8B7961; line-height: 1.5; flex: 1; }
.addr-empty { display: flex; align-items: center; gap: 12rpx; flex: 1; }
.addr-empty-icon { font-size: 32rpx; }
.addr-empty-text { font-size: 28rpx; color: #C0B8AE; }

/* ── 商品行 ── */
.order-item {
  display: flex;
  gap: 20rpx;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F0ECE6;
}
.order-item:last-child { border-bottom: none; }
.order-img { width: 120rpx; height: 120rpx; border-radius: 12rpx; background: #EAE6E0; flex-shrink: 0; }
.order-info { flex: 1; display: flex; flex-direction: column; justify-content: space-between; }
.order-name { font-size: 28rpx; color: #3A332D; font-weight: 500; }
.order-spec { font-size: 24rpx; color: #8B7961; }
.order-bottom { display: flex; align-items: center; justify-content: space-between; }
.order-price { font-size: 28rpx; font-weight: 700; color: #8B7961; }
.order-qty { font-size: 26rpx; color: #C0B8AE; }

/* ── 结算页件数调整 + 删除 ── */
.co-qty-ctrl { display: flex; align-items: center; gap: 12rpx; }
.co-qty-btn {
  width: 44rpx; height: 44rpx; border-radius: 50%;
  background: #F0ECE6; display: flex; align-items: center;
  justify-content: center; font-size: 28rpx; color: #3A332D; line-height: 1;
}
.co-qty-num { font-size: 28rpx; font-weight: 600; color: #3A332D; min-width: 36rpx; text-align: center; }
.co-del-btn {
  width: 40rpx; height: 40rpx; display: flex;
  align-items: center; justify-content: center;
  font-size: 28rpx; color: #C0B8AE; flex-shrink: 0; margin-left: 8rpx;
}

/* ── 优惠券行 ── */
.coupon-row { display: flex; align-items: center; }
.coupon-left { display: flex; align-items: center; gap: 12rpx; }
.coupon-icon { font-size: 32rpx; }
.coupon-label { font-size: 28rpx; color: #3A332D; }
.coupon-right { display: flex; align-items: center; gap: 8rpx; margin-left: auto; }
.coupon-val { font-size: 28rpx; color: #C0B8AE; }
.coupon-val.active { color: #C87941; font-weight: 600; }
.coupon-hint { font-size: 24rpx; color: #C87941; background: #FEF3EA; padding: 4rpx 12rpx; border-radius: 8rpx; }

/* ── 金额明细 ── */
.amount-card { }
.amount-row { display: flex; align-items: center; justify-content: space-between; padding: 14rpx 0; }
.amount-label { font-size: 26rpx; color: #8B7961; }
.amount-val { font-size: 26rpx; color: #3A332D; }
.amount-val.free { color: #6C9E6A; }
.amount-val.discount { color: #C87941; }
.amount-divider { height: 1rpx; background: #F0ECE6; margin: 4rpx 0; }
.total-row { padding-top: 18rpx; }
.amount-label-total { font-size: 28rpx; font-weight: 600; color: #3A332D; }
.amount-val-total { font-size: 40rpx; font-weight: 700; color: #3A332D; }

/* ── 备注 ── */
.remark-row { display: flex; align-items: center; gap: 16rpx; }
.remark-label { font-size: 28rpx; color: #3A332D; white-space: nowrap; }
.remark-input { flex: 1; font-size: 26rpx; color: #3A332D; text-align: right; height: 80rpx; line-height: 80rpx; }
.remark-placeholder { color: #C0B8AE; }

/* ── 底部操作栏 ── */
.bottom-bar {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  background: #FFFFFF;
  border-top: 1rpx solid #EAE6E0;
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  z-index: 50;
}
.bottom-total { flex: 1; }
.bt-label { font-size: 26rpx; color: #8B7961; }
.bt-price { font-size: 40rpx; font-weight: 700; color: #3A332D; margin-left: 8rpx; }
.pay-btn {
  background: #3A332D;
  color: #F6F3EF;
  font-size: 30rpx;
  font-weight: 500;
  padding: 22rpx 56rpx;
  border-radius: 48rpx;
}

/* ── 弹窗通用 ── */
.modal-mask {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(58,51,45,0.45); z-index: 100;
}
.modal-drag-bar {
  width: 80rpx; height: 8rpx; background: #D2C8BB;
  border-radius: 4rpx; margin: 20rpx auto 0;
}
.modal-hd {
  display: flex; justify-content: space-between; align-items: center;
  padding: 20rpx 0 16rpx;
}
.modal-title { font-size: 32rpx; font-weight: 600; color: #3A332D; }
.modal-close { font-size: 32rpx; color: #8B7961; padding: 8rpx; }

/* ── 优惠券弹窗 ── */
.coupon-modal {
  position: fixed; bottom: 0; left: 0; right: 0;
  background: #F6F3EF;
  border-radius: 32rpx 32rpx 0 0;
  padding: 0 32rpx;
  z-index: 101;
  max-height: 70vh;
}
.coupon-list { max-height: 55vh; }
.coupon-item {
  display: flex; align-items: center;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
  border: 2rpx solid transparent;
}
.coupon-item.selected { border-color: #8B7961; }
.coupon-body { flex: 1; }
.coupon-head { display: flex; align-items: center; gap: 12rpx; margin-bottom: 6rpx; }
.coupon-amt { font-size: 34rpx; font-weight: 700; color: #C87941; }
.coupon-tag { font-size: 20rpx; color: #C87941; background: #FEF3EA; padding: 3rpx 10rpx; border-radius: 6rpx; }
.coupon-name { display: block; font-size: 26rpx; color: #3A332D; margin-bottom: 4rpx; }
.coupon-min { display: block; font-size: 22rpx; color: #C0B8AE; }
.coupon-check { font-size: 28rpx; color: #8B7961; font-weight: 700; margin-left: 16rpx; }
.coupon-empty { text-align: center; padding: 40rpx 0; font-size: 26rpx; color: #C0B8AE; }

/* ── 支付弹窗 ── */
.pay-modal {
  position: fixed; bottom: 0; left: 0; right: 0;
  background: #F6F3EF;
  border-radius: 32rpx 32rpx 0 0;
  padding: 0 32rpx;
  z-index: 101;
}
.pay-amount-row {
  display: flex; justify-content: space-between; align-items: center;
  padding: 16rpx 0; border-top: 1rpx solid #EAE6E0; border-bottom: 1rpx solid #EAE6E0;
  margin-bottom: 24rpx;
}
.pay-amount-label { font-size: 26rpx; color: #8B7961; }
.pay-amount { font-size: 44rpx; font-weight: 700; color: #3A332D; }
.pay-method {
  display: flex; align-items: center;
  background: #FFFFFF; border-radius: 16rpx; padding: 20rpx;
  margin-bottom: 20rpx; border: 2rpx solid transparent;
}
.pay-method.active { border-color: #3A332D; }
.pay-icon { font-size: 40rpx; margin-right: 16rpx; }
.pay-name { flex: 1; font-size: 28rpx; color: #3A332D; }
.pay-check { font-size: 28rpx; color: #3A332D; font-weight: 700; }
.pay-dev-tip { display: block; font-size: 22rpx; color: #C0B8AE; text-align: center; margin-bottom: 16rpx; }
.pay-confirm-btn {
  width: 100%; background: #3A332D; color: #F6F3EF;
  border-radius: 48rpx; font-size: 32rpx; font-weight: 500;
  padding: 28rpx 0; text-align: center; border: none; line-height: 1;
}
.pay-confirm-btn::after { border: none; }

/* ── 礼品包装 ── */
.gift-card { display: flex; align-items: center; }
.gift-left { display: flex; align-items: center; gap: 16rpx; flex: 1; }
.gift-icon { font-size: 36rpx; }
.gift-info { display: flex; flex-direction: column; gap: 4rpx; }
.gift-name { font-size: 28rpx; font-weight: 500; color: #3A332D; display: block; }
.gift-tip { font-size: 22rpx; color: #8B7961; display: block; }
.gift-right { display: flex; align-items: center; gap: 16rpx; flex-shrink: 0; }
.gift-price { font-size: 26rpx; color: #C87941; font-weight: 600; }
.gift-toggle { width: 72rpx; height: 40rpx; background: #D2C8BB; border-radius: 20rpx; position: relative; }
.gift-toggle.on { background: #C87941; }
.gift-toggle-ball { width: 32rpx; height: 32rpx; background: #FFFFFF; border-radius: 50%; position: absolute; top: 4rpx; left: 4rpx; }
.gift-toggle.on .gift-toggle-ball { left: 36rpx; }
.amount-val.gift-fee { color: #C87941; }

/* ── 礼品袋商品卡 ── */
.gift-products-card { padding: 20rpx 24rpx; }
.gift-prod-hd { display: flex; align-items: baseline; justify-content: space-between; margin-bottom: 16rpx; }
.gift-prod-title { font-size: 26rpx; font-weight: 600; color: #3A332D; }
.gift-prod-sub { font-size: 22rpx; color: #C0B8AE; }
.gift-prod-item {
  display: flex; align-items: center; gap: 16rpx;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F0ECE6;
}
.gift-prod-item:last-child { border-bottom: none; }
.gift-prod-img { width: 96rpx; height: 96rpx; border-radius: 12rpx; background: #EAE6E0; flex-shrink: 0; }
.gift-prod-info { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 6rpx; }
.gift-prod-name { font-size: 26rpx; color: #3A332D; font-weight: 500; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.gift-prod-material { font-size: 22rpx; color: #8B7961; }
.gift-prod-size { font-size: 20rpx; color: #C0B8AE; }
.gift-prod-right { display: flex; flex-direction: column; align-items: flex-end; gap: 12rpx; flex-shrink: 0; }
.gift-prod-price { font-size: 26rpx; font-weight: 700; color: #C87941; }
.gift-add-btn {
  width: 52rpx; height: 52rpx; border-radius: 50%;
  background: #3A332D; display: flex; align-items: center; justify-content: center;
}
.gift-add-icon { font-size: 36rpx; color: #F6F3EF; line-height: 1; font-weight: 300; }
