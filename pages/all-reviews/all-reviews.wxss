page { background: #F5EFE6; }
.page { background: #F5EFE6; min-height: 100vh; }

.nav-bar {
  position: relative;
  display: flex; align-items: center;
  padding: 20rpx 28rpx;
  background: #F5EFE6;
}
.nav-back {
  width: 68rpx; height: 68rpx;
  display: flex; align-items: center; justify-content: center;
  z-index: 2;
}
.nav-back-icon { font-size: 52rpx; color: #2C1A0E; font-weight: 300; line-height: 1; }
.nav-title {
  position: absolute; left: 0; right: 0;
  text-align: center; font-size: 32rpx; font-weight: 600; color: #2C1A0E;
  pointer-events: none;
}

.rating-summary {
  display: flex; align-items: center; gap: 12rpx;
  padding: 16rpx 32rpx 0;
  background: #FFFFFF;
  margin: 0;
}
.rating-stars-row { display: flex; gap: 2rpx; }
.star-icon { font-size: 28rpx; }
.star-on { color: #F5A623; }
.star-half { color: #F5A623; opacity: 0.5; }
.star-off { color: #D2C8BB; }
.rating-score { font-size: 28rpx; font-weight: 700; color: #C87941; }
.rating-total { font-size: 24rpx; color: #9C8672; margin-left: auto; }

.empty-wrap {
  display: flex; flex-direction: column; align-items: center;
  padding: 100rpx 32rpx;
  gap: 16rpx;
}
.empty-icon { font-size: 80rpx; opacity: 0.3; }
.empty-text { font-size: 32rpx; color: #6B4F35; font-weight: 500; }
.empty-sub { font-size: 26rpx; color: #9C8672; }

/* ── 筛选 Tab ── */
.filter-tabs {
  display: flex; gap: 16rpx;
  padding: 20rpx 32rpx 24rpx;
  background: #FFFFFF;
  margin-bottom: 20rpx;
  border-top: 1rpx solid #F0ECE6;
}
.filter-tab {
  font-size: 26rpx; color: #8B7961;
  padding: 10rpx 24rpx; border-radius: 32rpx;
  background: #F0ECE6; border: 2rpx solid transparent;
}
.filter-tab-on {
  color: #C87941; background: #FEF3EA; border-color: #C87941; font-weight: 600;
}

.review-list { padding: 0 32rpx; }

.rv-item {
  background: #FFFFFF; border-radius: 20rpx;
  padding: 24rpx; margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(44,26,14,0.06);
  position: relative;
}
.rv-head { display: flex; align-items: center; gap: 16rpx; margin-bottom: 14rpx; }
.rv-avatar-bg {
  width: 56rpx; height: 56rpx; border-radius: 50%;
  background: #EDE5D8; display: flex; align-items: center;
  justify-content: center; flex-shrink: 0;
}
.rv-avatar-icon { font-size: 26rpx; line-height: 1; }
.rv-meta { flex: 1; }
.rv-user { font-size: 26rpx; font-weight: 500; color: #2C1A0E; display: block; margin-bottom: 6rpx; }
.rv-stars-row { display: flex; gap: 2rpx; }
.rv-star { font-size: 24rpx; }
.rv-star-on { color: #F5A623; }
.rv-star-off { color: #D2C8BB; }
.rv-date { font-size: 22rpx; color: #B0A090; flex-shrink: 0; }
/* SKU 规格标签 */
.rv-sku-tag {
  display: inline-flex; align-items: center;
  background: #F5F0EA; border: 1rpx solid #EDE5D8;
  border-radius: 8rpx; padding: 6rpx 16rpx;
  margin-bottom: 12rpx;
}
.rv-sku-text { font-size: 22rpx; color: #8B7961; }

.rv-content { font-size: 28rpx; color: #5A4535; line-height: 1.75; display: block; }
/* 评价图片 */
.rv-images { display: flex; flex-wrap: wrap; gap: 12rpx; margin: 14rpx 0 4rpx; }
.rv-img { width: 140rpx; height: 140rpx; border-radius: 10rpx; background: #EDE5D8; }

.rv-highlight-badge {
  margin-top: 12rpx;
  display: inline-flex; align-items: center;
  background: #FEF3EA; border-radius: 8rpx;
  padding: 4rpx 14rpx; border: 1rpx solid #F5E8D4;
}
.badge-text { font-size: 20rpx; color: #C87941; }
