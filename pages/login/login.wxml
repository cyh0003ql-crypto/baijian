<view class="page">
  <!-- 自定义导航 -->
  <view class="nav-bar">
    <view class="nav-back" bindtap="onBack">‹</view>
  </view>

  <!-- 品牌区 -->
  <view class="brand-section">
    <view class="brand-text-col">
      <text class="brand-name">Petit Aura</text>
      <text class="brand-sub">3D打印定制 · 拼豆 · 创意生活小物</text>
    </view>
  </view>

  <!-- 表单卡片 -->
  <view class="form-card">
    <text class="form-title">手机号登录 / 注册</text>

    <view class="field-group">
      <view class="field">
        <view class="field-icon-wrap">
          <text class="field-icon">📱</text>
        </view>
        <input
          class="field-input"
          type="number"
          maxlength="11"
          placeholder="请输入手机号"
          placeholder-class="field-placeholder"
          value="{{phone}}"
          bindinput="onPhoneInput"
        />
      </view>
      <view class="field-sep"></view>
      <view class="field">
        <view class="field-icon-wrap">
          <text class="field-icon">🔒</text>
        </view>
        <input
          class="field-input"
          password="{{!showPassword}}"
          placeholder="请输入密码（注册时自动设置）"
          placeholder-class="field-placeholder"
          value="{{password}}"
          bindinput="onPasswordInput"
        />
        <view class="eye-btn" bindtap="onTogglePassword">
          <text class="eye-icon">{{showPassword ? '👁' : '👁‍🗨'}}</text>
        </view>
      </view>
    </view>

    <button class="submit-btn {{isLoading ? 'loading' : ''}}" bindtap="onSubmit" disabled="{{isLoading}}">
      {{isLoading ? '登录中...' : '登录 / 注册'}}
    </button>

    <view class="divider-row">
      <view class="divider-line"></view>
      <text class="divider-text">或</text>
      <view class="divider-line"></view>
    </view>

    <button class="wx-btn" bindtap="onWxLogin">
      <text class="wx-icon">💚</text>
      <text class="wx-text">微信授权登录</text>
    </button>
  </view>

  <view class="tips">
    <text class="tips-text">登录即代表您已同意《用户协议》与《隐私政策》</text>
  </view>
</view>
