.page {
  height: 100vh;
  background: #F5EFE6;
}

/* 用户区 */
.user-section { padding: 32rpx 32rpx 0; }
.user-card {
  background: #FFFFFF;
  border-radius: 28rpx;
  padding: 28rpx 32rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
  box-shadow: 0 2rpx 16rpx rgba(44,26,14,0.07);
}
.user-avatar-wrap { flex-shrink: 0; }
.user-avatar-placeholder {
  width: 96rpx; height: 96rpx; border-radius: 50%;
  background: #EDE5D8; display: flex; align-items: center; justify-content: center;
}
.avatar-letter { font-size: 38rpx; color: #6B4F35; font-weight: 600; }
.avatar-img { width: 96rpx; height: 96rpx; border-radius: 50%; display: block; }
.avatar-icon-text { font-size: 40rpx; }
.user-info { flex: 1; }
.user-name { font-size: 32rpx; font-weight: 600; color: #2C1A0E; display: block; margin-bottom: 6rpx; }
.user-phone { font-size: 24rpx; color: #9C8672; display: block; }
.login-prompt { font-size: 32rpx; font-weight: 600; color: #2C1A0E; display: block; margin-bottom: 6rpx; }
.login-sub { font-size: 24rpx; color: #9C8672; display: block; }
.merchant-badge {
  background: #2C1A0E; color: #F5EFE6;
  font-size: 22rpx; padding: 6rpx 16rpx; border-radius: 8rpx; flex-shrink: 0;
}
.arrow { font-size: 36rpx; color: #C0B8AE; }

/* 订单卡片 */
.order-card {
  background: #FFFFFF;
  border-radius: 28rpx;
  margin: 24rpx 32rpx 0;
  padding: 28rpx 16rpx 24rpx;
  box-shadow: 0 2rpx 16rpx rgba(44,26,14,0.07);
}
.order-header {
  display: flex; justify-content: space-between; align-items: center;
  margin-bottom: 24rpx; padding: 0 16rpx;
}
.order-title { font-size: 28rpx; font-weight: 600; color: #2C1A0E; }
.order-all { font-size: 24rpx; color: #9C8672; }
.order-statuses { display: flex; justify-content: space-around; }
.status-item {
  display: flex; flex-direction: column; align-items: center; gap: 6rpx;
  flex: 1;
}
.status-icon-wrap {
  width: 72rpx; height: 72rpx; border-radius: 50%;
  background: #F5EFE6; display: flex; align-items: center; justify-content: center;
  margin-bottom: 4rpx;
}
.status-icon-text { font-size: 32rpx; }
.status-count { font-size: 34rpx; font-weight: 700; color: #2C1A0E; display: block; }
.status-name { font-size: 22rpx; color: #9C8672; display: block; }

/* 菜单卡片 */
.menu-card {
  background: #FFFFFF;
  border-radius: 28rpx;
  margin: 20rpx 32rpx 0;
  overflow: hidden;
  box-shadow: 0 2rpx 16rpx rgba(44,26,14,0.07);
}
.menu-item {
  display: flex;
  align-items: center;
  padding: 24rpx 28rpx;
  gap: 20rpx;
}
.menu-icon-circle {
  width: 72rpx; height: 72rpx; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.menu-icon-warm { background: #FFF0EA; }
.menu-icon-brown { background: #F5EFE6; }
.menu-icon-gold { background: #FFF8E7; }
.menu-icon-gray { background: #F0EEEC; }
.menu-icon-custom { background: #EEF4FF; }

/* 优惠券可领角标 */
.coupon-badge {
  background: #C87941;
  border-radius: 20rpx;
  padding: 6rpx 16rpx;
  margin-right: 8rpx;
}
.coupon-badge-text {
  font-size: 20rpx;
  color: #FFFFFF;
  font-weight: 600;
  line-height: 1;
}

/* 未读回复红点 */
.reply-badge {
  min-width: 36rpx;
  height: 36rpx;
  background: #E84040;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 10rpx;
  margin-right: 8rpx;
}
.reply-badge-text {
  font-size: 20rpx;
  color: #FFFFFF;
  font-weight: 700;
  line-height: 1;
}
.menu-icon-inner { font-size: 34rpx; }
.menu-label { flex: 1; font-size: 28rpx; color: #2C1A0E; }
.menu-arrow { font-size: 36rpx; color: #C0B8AE; }
.divider { height: 1rpx; background: #F5EFE6; margin: 0 28rpx; }

/* 商家入口 */
.merchant-entry {
  display: flex; align-items: center; gap: 20rpx;
  background: #2C1A0E; color: #F5EFE6;
  border-radius: 28rpx;
  margin: 20rpx 32rpx 0;
  padding: 28rpx;
}
.merchant-entry-icon-wrap {
  width: 72rpx; height: 72rpx; border-radius: 50%;
  background: rgba(255,255,255,0.12);
  display: flex; align-items: center; justify-content: center;
}
.merchant-entry-icon { font-size: 36rpx; }
.merchant-entry-text { flex: 1; font-size: 28rpx; color: #F5EFE6; font-weight: 500; }
.merchant-arrow { font-size: 36rpx; color: rgba(255,255,255,0.4); }

/* 退出 */
.logout-btn {
  text-align: center;
  margin: 28rpx 32rpx 0;
  padding: 28rpx;
  background: #FFFFFF;
  border-radius: 28rpx;
  font-size: 28rpx;
  color: #9C8672;
  box-shadow: 0 2rpx 16rpx rgba(44,26,14,0.07);
}
