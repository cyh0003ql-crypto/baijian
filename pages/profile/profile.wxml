<scroll-view scroll-y class="page">

  <!-- 用户信息区（已登录） -->
  <view class="user-section" wx:if="{{isLoggedIn}}">
    <view class="user-card" bindtap="onEditProfile">
      <view class="user-avatar-wrap">
        <view class="user-avatar-placeholder">
          <image wx:if="{{userInfo.avatar}}" class="avatar-img" src="{{userInfo.avatar}}" mode="aspectFill" />
          <text wx:else class="avatar-letter">{{userInfo.name ? userInfo.name.substring(0,1) : '我'}}</text>
        </view>
      </view>
      <view class="user-info">
        <text class="user-name">{{userInfo.name || '艺术爱好者'}}</text>
        <text class="user-phone">{{userInfo.phone || '点击编辑个人资料'}}</text>
      </view>
      <view class="merchant-badge" wx:if="{{isMerchant}}">商家</view>
      <text class="arrow" wx:else>›</text>
    </view>
  </view>

  <!-- 未登录 -->
  <view class="user-section" wx:else>
    <view class="user-card" bindtap="onLogin">
      <view class="user-avatar-wrap">
        <view class="user-avatar-placeholder">
          <text class="avatar-icon-text">👤</text>
        </view>
      </view>
      <view class="user-info">
        <text class="login-prompt">点击登录 / 注册</text>
        <text class="login-sub">登录后享受更多权益</text>
      </view>
      <text class="arrow">›</text>
    </view>
  </view>

  <!-- 订单状态 -->
  <view class="order-card">
    <view class="order-header">
      <text class="order-title">我的订单</text>
      <text class="order-all" bindtap="onOrders" data-status="">全部订单 ›</text>
    </view>
    <view class="order-statuses">
      <view class="status-item" bindtap="onOrders" data-status="paid">
        <view class="status-icon-wrap">
          <text class="status-icon-text">📦</text>
        </view>
        <text class="status-count">{{orderCounts.paid}}</text>
        <text class="status-name">待发货</text>
      </view>
      <view class="status-item" bindtap="onOrders" data-status="shipped">
        <view class="status-icon-wrap">
          <text class="status-icon-text">🚚</text>
        </view>
        <text class="status-count">{{orderCounts.shipped}}</text>
        <text class="status-name">已发货</text>
      </view>
      <view class="status-item" bindtap="onOrders" data-status="completed">
        <view class="status-icon-wrap">
          <text class="status-icon-text">✅</text>
        </view>
        <text class="status-count">{{orderCounts.completed}}</text>
        <text class="status-name">已完成</text>
      </view>
      <view class="status-item" bindtap="onOrders" data-status="">
        <view class="status-icon-wrap">
          <text class="status-icon-text">📋</text>
        </view>
        <text class="status-count">{{orderCounts.all}}</text>
        <text class="status-name">全部</text>
      </view>
    </view>
  </view>

  <!-- 功能列表 -->
  <view class="menu-card">
    <view class="menu-item" bindtap="onMyCustom">
      <view class="menu-icon-circle menu-icon-custom">
        <text class="menu-icon-inner">✏️</text>
      </view>
      <text class="menu-label">我的定制</text>
      <view class="reply-badge" wx:if="{{unreadReplyCount > 0}}">
        <text class="reply-badge-text">{{unreadReplyCount}}</text>
      </view>
      <text class="menu-arrow" wx:else>›</text>
    </view>
    <view class="divider"></view>
    <view class="menu-item" bindtap="onFavorites">
      <view class="menu-icon-circle menu-icon-warm">
        <text class="menu-icon-inner">♥</text>
      </view>
      <text class="menu-label">我的收藏</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="divider"></view>
    <view class="menu-item" bindtap="onAddress">
      <view class="menu-icon-circle menu-icon-brown">
        <text class="menu-icon-inner">📍</text>
      </view>
      <text class="menu-label">收货地址</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="divider"></view>
    <view class="menu-item" bindtap="onCoupons">
      <view class="menu-icon-circle menu-icon-gold">
        <text class="menu-icon-inner">🎫</text>
      </view>
      <text class="menu-label">我的优惠券</text>
      <view class="coupon-badge" wx:if="{{claimableCount > 0}}">
        <text class="coupon-badge-text">{{claimableCount}}张可领</text>
      </view>
      <text class="menu-arrow" wx:else>›</text>
    </view>
  </view>

  <view class="menu-card">
    <view class="menu-item" bindtap="onContactService">
      <view class="menu-icon-circle menu-icon-gray">
        <text class="menu-icon-inner">🎧</text>
      </view>
      <text class="menu-label">联系客服</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="divider"></view>
    <view class="menu-item" bindtap="onAbout">
      <view class="menu-icon-circle menu-icon-gray">
        <text class="menu-icon-inner">ℹ️</text>
      </view>
      <text class="menu-label">关于我们</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <!-- 商家入口 -->
  <view class="merchant-entry" bindtap="onMerchantEntry">
    <view class="merchant-entry-icon-wrap">
      <text class="merchant-entry-icon">🏪</text>
    </view>
    <text class="merchant-entry-text">{{isMerchant ? '进入商家后台' : '商家登录入口'}}</text>
    <text class="merchant-arrow">›</text>
  </view>

  <!-- 退出按钮 -->
  <view wx:if="{{isLoggedIn}}" class="logout-btn" bindtap="onLogout">退出登录</view>

  <view style="height:200rpx;"></view>
</scroll-view>
