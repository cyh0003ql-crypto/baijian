.page { background: #F0ECE6; min-height: 100vh; }

/* 物流信息行 */
.tracking-row { display: flex; align-items: flex-start; padding: 14rpx 24rpx; background: #EAF4FF; border-top: 1rpx solid #D0E8FA; gap: 12rpx; }
.tracking-label { font-size: 22rpx; color: #4A7CC7; flex-shrink: 0; padding-top: 2rpx; }
.tracking-info { display: flex; align-items: center; gap: 12rpx; flex-wrap: wrap; }
.tracking-carrier { font-size: 22rpx; color: #4A7CC7; font-weight: 600; background: #D0E8FA; padding: 4rpx 12rpx; border-radius: 10rpx; }
.tracking-num { font-size: 22rpx; color: #2C6FAC; font-family: monospace; }

/* 暂无物流信息 */
.no-tracking-row { padding: 14rpx 24rpx; background: #FAFAF8; border-top: 1rpx solid #F0ECE6; }
.no-tracking-text { font-size: 22rpx; color: #C0B8AE; }

/* 查看物流按钮 */
.action-btn-track { flex: 1; text-align: center; padding: 20rpx 0; border-radius: 16rpx; font-size: 26rpx; font-weight: 500; background: #EAF0FE; color: #4A7CC7; border: 1rpx solid #C0D4F8; }

/* 标签栏 */
.tabs {
  display: flex;
  background: #FFFFFF;
  border-bottom: 1rpx solid #EAE6E0;
  position: sticky; top: 0; z-index: 10;
}
.tab-item {
  flex: 1; text-align: center; padding: 28rpx 0;
  border-bottom: 4rpx solid transparent;
}
.tab-item.active { border-bottom-color: #3A332D; }
.tab-label { font-size: 26rpx; color: #8B7961; }
.tab-item.active .tab-label { color: #3A332D; font-weight: 600; }

/* 滚动 */
.orders-scroll { height: calc(100vh - 100rpx); }
.orders-list { padding: 20rpx 24rpx; }

/* 订单卡片 */
.order-card {
  background: #FFFFFF; border-radius: 20rpx;
  overflow: hidden; margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(58,51,45,0.06);
}
.order-head {
  display: flex; justify-content: space-between; align-items: center;
  padding: 24rpx 24rpx 16rpx;
  border-bottom: 1rpx solid #F0ECE6;
}
.order-id { font-size: 24rpx; color: #8B7961; }
.order-status { font-size: 26rpx; font-weight: 600; }
.order-status.paid { color: #C87941; }
.order-status.shipped { color: #4A7CC7; }
.order-status.completed { color: #5A9A6A; }
.order-status.cancelled { color: #C0B8AE; }

/* 商品 */
.order-products { padding: 16rpx 24rpx; }
.order-prod-item { display: flex; gap: 20rpx; padding: 12rpx 0; border-bottom: 1rpx solid #F0ECE6; }
.order-prod-item:last-child { border-bottom: none; }
.prod-img { width: 120rpx; height: 120rpx; border-radius: 12rpx; background: #EAE6E0; flex-shrink: 0; }
.prod-info { flex: 1; display: flex; flex-direction: column; }
.prod-name { font-size: 28rpx; color: #3A332D; display: block; margin-bottom: 6rpx; }
.prod-spec { font-size: 24rpx; color: #8B7961; display: block; margin-bottom: 10rpx; }
.prod-bottom { display: flex; justify-content: space-between; align-items: center; }
.prod-price { font-size: 28rpx; color: #8B7961; font-weight: 600; }
.prod-qty { font-size: 24rpx; color: #C0B8AE; }

/* 下单时间 */
.order-date-row {
  display: flex; align-items: center; gap: 12rpx;
  padding: 10rpx 24rpx; border-bottom: 1rpx solid #F0ECE6;
}
.order-date-label { font-size: 22rpx; color: #C0B8AE; flex-shrink: 0; }
.order-date-val { font-size: 22rpx; color: #8B7961; }

/* 价格明细 */
.price-detail {
  padding: 16rpx 24rpx 8rpx;
  border-top: 1rpx solid #F0ECE6;
  background: #FAFAF8;
}
.price-row-item {
  display: flex; justify-content: space-between; align-items: center;
  padding: 7rpx 0;
}
.price-label { font-size: 24rpx; color: #8B7961; }
.price-val { font-size: 24rpx; color: #3A332D; }
.coupon-row { align-items: flex-start; }
.coupon-info { display: flex; flex-direction: column; align-items: flex-end; gap: 4rpx; }
.price-coupon-name { font-size: 20rpx; color: #C87941; background: #FEF3EA; padding: 2rpx 10rpx; border-radius: 6rpx; }
.discount-val { color: #C87941; font-weight: 600; }
.price-total-row {
  display: flex; justify-content: space-between; align-items: center;
  padding: 12rpx 0 4rpx;
  border-top: 1rpx solid #EAE6E0;
  margin-top: 6rpx;
}
.price-total-label { font-size: 26rpx; color: #3A332D; font-weight: 600; }
.price-total-val { font-size: 32rpx; color: #6B4F35; font-weight: 700; }

/* 备注 */
.remark-row {
  display: flex; align-items: flex-start; gap: 12rpx;
  padding: 14rpx 24rpx; border-top: 1rpx solid #F0ECE6;
  background: #FAFAF8;
}
.remark-label { font-size: 22rpx; color: #8B7961; flex-shrink: 0; }
.remark-val { font-size: 24rpx; color: #3A332D; flex: 1; line-height: 1.5; }

/* 收货地址 */
.addr-row {
  display: flex; align-items: flex-start; gap: 12rpx;
  padding: 14rpx 24rpx; border-top: 1rpx solid #F0ECE6;
}
.addr-label { font-size: 22rpx; color: #8B7961; flex-shrink: 0; }
.addr-val { font-size: 22rpx; color: #3A332D; flex: 1; line-height: 1.5; }

/* 操作 */
.order-actions { padding: 16rpx 24rpx 20rpx; display: flex; justify-content: flex-end; gap: 16rpx; border-top: 1rpx solid #F0ECE6; }
.action-btn-outline {
  border: 2rpx solid #3A332D; color: #3A332D;
  font-size: 26rpx; padding: 14rpx 32rpx; border-radius: 32rpx;
}

/* 空状态 */
.empty-state {
  display: flex; flex-direction: column; align-items: center;
  justify-content: center; padding: 120rpx 32rpx;
}
.empty-icon { font-size: 100rpx; margin-bottom: 24rpx; opacity: 0.4; }
.empty-text { font-size: 28rpx; color: #8B7961; }

.action-btn-review {
  flex: 1; text-align: center; padding: 20rpx 0; border-radius: 16rpx;
  font-size: 26rpx; font-weight: 500;
  background: #2C1A0E; color: #F5EFE6;
}
.action-btn-reviewed {
  flex: 1; text-align: center; padding: 20rpx 0; border-radius: 16rpx;
  font-size: 26rpx; color: #9C8672; background: #F0ECE6;
}
