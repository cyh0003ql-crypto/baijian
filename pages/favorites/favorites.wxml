<view class="page">
  <view wx:if="{{favorites.length === 0}}" class="empty-state">
    <text class="empty-icon">🤍</text>
    <text class="empty-text">还没有收藏任何商品</text>
    <view class="go-btn" bindtap="onGoShop">去逛逛</view>
  </view>

  <scroll-view scroll-y class="fav-scroll" wx:else>
    <view class="fav-grid">
      <view class="fav-card" wx:for="{{favorites}}" wx:key="id">
        <view class="fav-img-wrap" bindtap="onProductTap" data-id="{{item.id}}">
          <image src="{{item.image}}" mode="aspectFill" class="fav-img" />
          <view class="remove-btn" catchtap="onRemove" data-id="{{item.id}}">❤️</view>
        </view>
        <view class="fav-info" bindtap="onProductTap" data-id="{{item.id}}">
          <text class="fav-name">{{item.name}}</text>
          <view class="fav-bottom">
            <text class="fav-price">¥{{item.price}}</text>
            <view class="cart-btn" catchtap="onAddToCart" data-id="{{item.id}}">+</view>
          </view>
        </view>
      </view>
    </view>
    <view style="height:40rpx;"></view>
  </scroll-view>
</view>
