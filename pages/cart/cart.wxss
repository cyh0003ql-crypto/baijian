.page {
  background: #F5EFE6;
  min-height: 100vh;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 32rpx;
}
.empty-icon { font-size: 100rpx; margin-bottom: 24rpx; opacity: 0.35; }
.empty-text { font-size: 32rpx; color: #2C1A0E; font-weight: 500; margin-bottom: 12rpx; }
.empty-sub { font-size: 26rpx; color: #9C8672; margin-bottom: 40rpx; }
.go-shop-btn {
  background: #2C1A0E;
  color: #F5EFE6;
  font-size: 28rpx;
  padding: 20rpx 60rpx;
  border-radius: 48rpx;
}

.cart-scroll { height: calc(100vh - 120rpx); }

/* 购物车列表 */
.cart-list { padding: 16rpx; }

.cart-item {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 14rpx rgba(44,26,14,0.06);
  gap: 16rpx;
}

/* 复选框 */
.checkbox {
  width: 44rpx;
  height: 44rpx;
  border: 2rpx solid #D2C8BB;
  border-radius: 50%;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}
.checkbox.checked {
  background: #2C1A0E;
  border-color: #2C1A0E;
}
.check-mark { color: #F5EFE6; font-size: 24rpx; font-weight: 700; }

/* 商品图 */
.item-img {
  width: 140rpx;
  height: 140rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
  background: #EDE5D8;
}

/* 商品信息 */
.item-info { flex: 1; min-width: 0; }
.item-name {
  font-size: 28rpx;
  color: #2C1A0E;
  display: block;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-weight: 500;
}
.item-spec { font-size: 24rpx; color: #9C8672; display: block; margin-bottom: 16rpx; }
.item-bottom { display: flex; align-items: center; justify-content: space-between; }
.item-price { font-size: 30rpx; font-weight: 700; color: #6B4F35; }

/* 数量控制 */
.qty-ctrl {
  display: flex;
  align-items: center;
  background: #EDE5D8;
  border-radius: 32rpx;
  overflow: hidden;
}
.qty-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.qty-icon { font-size: 32rpx; color: #2C1A0E; }
.qty-num { width: 56rpx; text-align: center; font-size: 28rpx; color: #2C1A0E; font-weight: 600; }

/* 删除按钮 */
.delete-btn {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.delete-icon { font-size: 40rpx; color: #C0B8AE; }

/* 结算栏 */
.checkout-bar {
  position: fixed;
  bottom: 0;
  left: 0; right: 0;
  background: #F5EFE6;
  border-top: 1rpx solid #EDE5D8;
  display: flex;
  align-items: center;
  padding: 20rpx 28rpx;
  padding-bottom: calc(150rpx + env(safe-area-inset-bottom));
  z-index: 100;
}
.select-all { display: flex; align-items: center; gap: 12rpx; margin-right: 24rpx; }
.select-all-text { font-size: 26rpx; color: #2C1A0E; }
.total-area { flex: 1; }
.total-label { font-size: 26rpx; color: #9C8672; }
.total-price { font-size: 36rpx; font-weight: 700; color: #2C1A0E; }
.checkout-btn {
  background: #2C1A0E;
  color: #F5EFE6;
  font-size: 28rpx;
  font-weight: 500;
  padding: 20rpx 32rpx;
  border-radius: 48rpx;
}
.checkout-btn.disabled { background: #C0B8AE; }
.safe-bottom { height: env(safe-area-inset-bottom); }

/* 支付弹窗 */
.modal-mask {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(44,26,14,0.5); z-index: 200;
}
.pay-modal {
  position: fixed; bottom: 0; left: 0; right: 0;
  background: #F5EFE6;
  border-radius: 32rpx 32rpx 0 0;
  padding: 32rpx;
  z-index: 201;
}
.modal-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 28rpx; }
.modal-title { font-size: 34rpx; font-weight: 600; color: #2C1A0E; }
.modal-close { font-size: 32rpx; color: #9C8672; padding: 8rpx; }
.modal-total-row {
  display: flex; justify-content: space-between; align-items: center;
  background: #FFFFFF; border-radius: 16rpx; padding: 24rpx; margin-bottom: 20rpx;
}
.modal-total-label { font-size: 28rpx; color: #9C8672; }
.modal-total-val { font-size: 40rpx; font-weight: 700; color: #2C1A0E; }
.pay-methods { margin-bottom: 16rpx; }
.pay-method {
  display: flex; align-items: center;
  padding: 20rpx; border-radius: 16rpx; margin-bottom: 12rpx; background: #FFFFFF;
}
.pay-method.active { border: 2rpx solid #2C1A0E; }
.pay-icon { font-size: 40rpx; margin-right: 16rpx; }
.pay-name { flex: 1; font-size: 28rpx; color: #2C1A0E; }
.pay-check { font-size: 28rpx; color: #2C1A0E; font-weight: 600; }
.modal-tip { font-size: 22rpx; color: #C0B8AE; text-align: center; margin-bottom: 20rpx; }
.pay-confirm-btn {
  width: 100%; background: #2C1A0E; color: #F5EFE6;
  border-radius: 48rpx; font-size: 32rpx; font-weight: 500;
  padding: 28rpx 0; text-align: center; border: none; line-height: 1;
}
.pay-confirm-btn::after { border: none; }
