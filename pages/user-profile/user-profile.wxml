<view class="page">
  <!-- 头像区 -->
  <view class="avatar-section" bindtap="onChangeAvatar">
    <view class="avatar-circle">
      <image wx:if="{{avatar}}" class="avatar-img" src="{{avatar}}" mode="aspectFill" />
      <text wx:else class="avatar-text">{{name ? name.substring(0,1) : '我'}}</text>
    </view>
    <view class="avatar-edit-hint">
      <text class="avatar-tip">点击修改个人信息</text>
      <text class="avatar-change">更换头像</text>
    </view>
  </view>

  <!-- 表单 -->
  <view class="form-card">
    <view class="form-row">
      <text class="form-label">昵　称</text>
      <input
        class="form-input"
        placeholder="请输入昵称"
        placeholder-class="form-placeholder"
        value="{{name}}"
        bindinput="onNameInput"
        maxlength="20"
      />
    </view>
    <view class="form-divider"></view>
    <view class="form-row">
      <text class="form-label">手机号</text>
      <input
        class="form-input"
        placeholder="请输入手机号"
        placeholder-class="form-placeholder"
        value="{{phone}}"
        bindinput="onPhoneInput"
        type="number"
        maxlength="11"
      />
    </view>
    <view class="form-divider"></view>
    <view class="form-row bio-row">
      <text class="form-label">简　介</text>
      <textarea
        class="form-textarea"
        placeholder="介绍一下自己..."
        placeholder-class="form-placeholder"
        value="{{bio}}"
        bindinput="onBioInput"
        maxlength="100"
        auto-height
      />
    </view>
  </view>

  <!-- 保存按钮 -->
  <button
    class="save-btn {{isSaving ? 'saving' : ''}}"
    bindtap="onSave"
    disabled="{{isSaving}}"
  >
    {{isSaving ? '保存中...' : '保存修改'}}
  </button>
</view>
