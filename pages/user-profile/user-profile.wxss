page {
  background: #F5EFE6;
  height: 100%;
}

.page {
  background: #F5EFE6;
  min-height: 100vh;
  padding-bottom: 60rpx;
}

/* 头像区 */
.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 56rpx 32rpx 36rpx;
}

.avatar-section {
  cursor: pointer;
}

.avatar-circle {
  width: 130rpx;
  height: 130rpx;
  background: #EDE5D8;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(44,26,14,0.1);
  overflow: hidden;
}

.avatar-img {
  width: 130rpx;
  height: 130rpx;
  border-radius: 50%;
}

.avatar-text {
  font-size: 56rpx;
  color: #6B4F35;
  font-weight: 600;
  line-height: 1;
}

.avatar-edit-hint {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.avatar-tip {
  font-size: 24rpx;
  color: #9C8672;
  display: block;
}

.avatar-change {
  font-size: 22rpx;
  color: #C87341;
  display: block;
}

/* 表单卡片 */
.form-card {
  margin: 0 32rpx 32rpx;
  background: #FFFFFF;
  border-radius: 28rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 16rpx rgba(44,26,14,0.07);
}

.form-row {
  display: flex;
  align-items: center;
  padding: 30rpx 32rpx;
  min-height: 88rpx;
}

.bio-row {
  align-items: flex-start;
  padding-top: 24rpx;
}

.form-label {
  font-size: 28rpx;
  color: #2C1A0E;
  font-weight: 500;
  width: 100rpx;
  flex-shrink: 0;
  letter-spacing: 2rpx;
}

.form-input {
  flex: 1;
  font-size: 28rpx;
  color: #2C1A0E;
  text-align: right;
  height: 80rpx;
  line-height: 80rpx;
}

.form-textarea {
  flex: 1;
  font-size: 28rpx;
  color: #2C1A0E;
  text-align: right;
  min-height: 100rpx;
  line-height: 1.6;
}

.form-placeholder {
  color: #C0B8AE;
  font-size: 28rpx;
}

.form-divider {
  height: 1rpx;
  background: #EDE5D8;
  margin: 0 32rpx;
}

/* 保存按钮 */
.save-btn {
  display: block;
  margin: 0 32rpx;
  background: #2C1A0E;
  color: #F5EFE6;
  text-align: center;
  font-size: 32rpx;
  font-weight: 500;
  padding: 30rpx 0;
  border-radius: 48rpx;
  border: none;
  line-height: 1;
  box-shadow: 0 6rpx 24rpx rgba(44,26,14,0.2);
}

.save-btn::after {
  border: none;
}

.save-btn.saving {
  opacity: 0.6;
}
