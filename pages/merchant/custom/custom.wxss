page { background: #F5EFE6; }

.page {
  background: #F5EFE6;
  min-height: 100vh;
  padding: 24rpx 24rpx 40rpx;
}

.m-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
  padding: 0 8rpx;
}

.m-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #2C1A0E;
}

.m-count {
  font-size: 24rpx;
  color: #9C8672;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-icon { font-size: 80rpx; margin-bottom: 20rpx; }
.empty-text { font-size: 30rpx; color: #6B4F35; font-weight: 500; }
.empty-sub { font-size: 24rpx; color: #9C8672; margin-top: 10rpx; }

.request-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(44,26,14,0.07);
}

.card-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #F0EBE0;
}

.req-id {
  font-size: 22rpx;
  color: #9C8672;
  font-family: monospace;
}

.status-tag {
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
}

.status-tag.pending { background: #FFF3E0; color: #C87341; }
.status-tag.processing { background: #E8F4FD; color: #2196F3; }
.status-tag.completed { background: #E8F5E9; color: #4CAF50; }

.info-section {
  margin-bottom: 16rpx;
}

.info-label {
  display: block;
  font-size: 22rpx;
  color: #9C8672;
  margin-bottom: 6rpx;
}

.info-val {
  font-size: 28rpx;
  color: #2C1A0E;
  display: block;
}

.info-val.desc {
  line-height: 1.6;
  color: #6B4F35;
}

.user-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.user-name {
  font-size: 28rpx;
  color: #2C1A0E;
  font-weight: 500;
}

.user-phone {
  font-size: 26rpx;
  color: #6B4F35;
  background: #F5EFE6;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.img-scroll {
  white-space: nowrap;
  width: 100%;
}

.req-img {
  width: 140rpx;
  height: 140rpx;
  border-radius: 12rpx;
  margin-right: 12rpx;
  display: inline-block;
  object-fit: cover;
}

/* 商家回复区 */
.reply-section {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #F0EBE0;
}

.reply-bubble {
  background: #EAF4FF;
  border-radius: 16rpx;
  padding: 16rpx 20rpx;
  border-left: 4rpx solid #6B8FD4;
  margin-bottom: 10rpx;
  position: relative;
}

.reply-bubble-label {
  display: block;
  font-size: 20rpx;
  color: #4A6FAD;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.reply-bubble-text {
  display: block;
  font-size: 26rpx;
  color: #2C3F6B;
  line-height: 1.6;
  margin-bottom: 8rpx;
}

.reply-bubble-time {
  display: block;
  font-size: 20rpx;
  color: #9AAACF;
  margin-bottom: 8rpx;
}

.reply-edit-btn {
  font-size: 22rpx;
  color: #4A7CC7;
  display: inline-block;
}

.reply-input-area {
  background: #F5EFE6;
  border-radius: 16rpx;
  padding: 16rpx;
  margin-bottom: 10rpx;
}

.reply-textarea {
  width: 100%;
  min-height: 100rpx;
  font-size: 26rpx;
  color: #2C1A0E;
  line-height: 1.6;
  background: transparent;
}

.reply-placeholder {
  color: #C0B8AE;
  font-size: 24rpx;
}

.reply-btns {
  display: flex;
  gap: 12rpx;
  margin-top: 12rpx;
  justify-content: flex-end;
}

.reply-cancel {
  padding: 12rpx 28rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
  background: #EDE5D8;
  color: #6B4F35;
}

.reply-send {
  padding: 12rpx 28rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
  font-weight: 600;
  background: #2C1A0E;
  color: #F5EFE6;
}

.reply-trigger {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 6rpx 0;
}

.reply-trigger-icon { font-size: 28rpx; }
.reply-trigger-text { font-size: 24rpx; color: #4A7CC7; }

.act-row {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #F0EBE0;
}

.act-btn {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  border-radius: 16rpx;
  font-size: 26rpx;
  font-weight: 500;
}

.call-btn { background: #EDE5D8; color: #6B4F35; }
.proc-btn { background: #E8F4FD; color: #2196F3; }
.done-btn { background: #E8F5E9; color: #388E3C; }
