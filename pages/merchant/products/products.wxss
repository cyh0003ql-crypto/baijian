.page { background: #F0ECE6; min-height: 100vh; }

/* ── 标签栏 ── */
.tab-bar {
  display: flex; background: #FFFFFF;
  border-bottom: 1rpx solid #EAE6E0;
}
.tab-item {
  flex: 1; text-align: center; padding: 22rpx 0;
  font-size: 28rpx; color: #8B7961; position: relative;
  display: flex; align-items: center; justify-content: center; gap: 8rpx;
}
.tab-item.active { color: #3A332D; font-weight: 600; }
.tab-item.active::after {
  content: ''; position: absolute; bottom: 0; left: 20%; right: 20%;
  height: 4rpx; background: #C87941; border-radius: 2rpx;
}
.tab-count-badge {
  background: #C87941; color: #FFFFFF;
  font-size: 18rpx; padding: 2rpx 8rpx; border-radius: 16rpx;
}

.prod-origin { font-size: 22rpx; color: #B0A090; text-decoration: line-through; }
.badge.newbie-tag { background: #FEF0E0; color: #C87941; }

.toolbar {
  display: flex; align-items: center; justify-content: space-between;
  padding: 20rpx 24rpx; background: #FFFFFF;
  border-bottom: 1rpx solid #EAE6E0;
}
.tool-count { font-size: 26rpx; color: #8B7961; }
.add-btn { background: #3A332D; color: #F6F3EF; font-size: 24rpx; padding: 14rpx 28rpx; border-radius: 32rpx; }
.prod-scroll { height: calc(100vh - 96rpx); }
.prod-list { padding: 16rpx 24rpx; }
.prod-card {
  background: #FFFFFF; border-radius: 20rpx; margin-bottom: 16rpx;
  overflow: hidden; box-shadow: 0 2rpx 12rpx rgba(58,51,45,0.06);
  display: flex; gap: 20rpx; padding: 20rpx;
}
.prod-img { width: 120rpx; height: 120rpx; border-radius: 12rpx; background: #EAE6E0; flex-shrink: 0; }
.prod-info { flex: 1; min-width: 0; }
.prod-name-row { display: flex; align-items: center; gap: 12rpx; margin-bottom: 8rpx; }
.prod-name { font-size: 28rpx; color: #3A332D; flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.prod-id { font-size: 20rpx; color: #FFFFFF; background: #8B7961; padding: 3rpx 10rpx; border-radius: 8rpx; flex-shrink: 0; }
.prod-meta { display: flex; gap: 20rpx; align-items: center; margin-bottom: 12rpx; }
.prod-price { font-size: 28rpx; color: #8B7961; font-weight: 600; }
.prod-stock { font-size: 24rpx; color: #8B7961; }
.prod-stock.low { color: #C87941; }
/* ── 销量信息行 ── */
.sold-info-row {
  display: flex; gap: 12rpx; margin-bottom: 12rpx; flex-wrap: wrap;
}
.sold-item {
  display: flex; align-items: center; gap: 8rpx;
  border-radius: 12rpx; padding: 8rpx 16rpx;
  flex-shrink: 0;
}
.sold-item.display-sold { background: #FEF3EA; }
.sold-item.real-sold { background: #EAE6E0; }
.sold-label { font-size: 20rpx; color: #8B7961; }
.sold-val { font-size: 24rpx; font-weight: 700; color: #3A332D; }
.sold-edit-icon { font-size: 20rpx; color: #C87941; }

.prod-badges { display: flex; gap: 10rpx; }
.badge { font-size: 20rpx; padding: 4rpx 12rpx; border-radius: 8rpx; background: #F0ECE6; color: #8B7961; }
.badge.on { background: #3A332D; color: #F6F3EF; }
.prod-actions { display: flex; flex-direction: column; gap: 10rpx; justify-content: center; }
.act-btn { font-size: 22rpx; padding: 10rpx 16rpx; border-radius: 12rpx; text-align: center; }
.act-btn.stock { background: #EAE6E0; color: #3A332D; }
.act-btn.edit { background: #3A332D; color: #F6F3EF; }
.act-btn.del { background: #F5E8E0; color: #C87941; }
.empty-state { display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 120rpx 32rpx; }
.empty-icon { font-size: 100rpx; margin-bottom: 24rpx; opacity: 0.4; }
.empty-text { font-size: 28rpx; color: #8B7961; }
