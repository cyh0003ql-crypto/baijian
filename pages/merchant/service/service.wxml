<scroll-view scroll-y class="page">
  <view class="page-title">客服设置</view>

  <!-- 微信号 -->
  <view class="form-section">
    <text class="section-label">客服信息</text>
    <view class="form-group">
      <view class="field">
        <text class="f-label">微信号</text>
        <input class="f-input" placeholder="客服微信号" value="{{form.wechatId}}" bindinput="onInput" data-field="wechatId" />
      </view>
      <view class="field">
        <text class="f-label">服务时间</text>
        <input class="f-input" placeholder="如：工作日 9:00-18:00" value="{{form.description}}" bindinput="onInput" data-field="description" />
      </view>
    </view>
  </view>

  <!-- 添加说明 -->
  <view class="form-section">
    <text class="section-label">添加说明</text>
    <view class="desc-wrap">
      <textarea class="desc-input" placeholder="提示用户如何添加客服..." value="{{form.note}}" bindinput="onInput" data-field="note" />
    </view>
  </view>

  <!-- 客服二维码 -->
  <view class="form-section">
    <text class="section-label">客服二维码</text>
    <view class="qr-picker-wrap">
      <view wx:if="{{form.qrPath}}" class="qr-preview-wrap">
        <image src="{{form.qrPath}}" mode="aspectFit" class="qr-preview" bindtap="onPreviewQr" />
        <view class="qr-actions">
          <view class="qr-btn" bindtap="onChooseQr">更换图片</view>
          <view class="qr-btn danger" bindtap="onClearQr">删除</view>
        </view>
      </view>
      <view wx:else class="qr-empty" bindtap="onChooseQr">
        <text class="qr-empty-icon">📷</text>
        <text class="qr-empty-text">点击上传二维码图片</text>
      </view>
    </view>
  </view>

  <button class="save-btn" bindtap="onSave">保存设置</button>
  <view style="height:60rpx;"></view>
</scroll-view>
