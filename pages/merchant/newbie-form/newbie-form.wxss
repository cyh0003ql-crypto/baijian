.page { background: #F0ECE6; height: 100vh; }
.page-title { font-size: 32rpx; font-weight: 600; color: #3A332D; padding: 28rpx 24rpx 0; }
.form-section { padding: 20rpx 24rpx 0; }
.section-label { font-size: 24rpx; color: #8B7961; display: block; margin-bottom: 12rpx; text-transform: uppercase; letter-spacing: 1rpx; }
.form-group { background: #FFFFFF; border-radius: 20rpx; overflow: hidden; }
.field { display: flex; align-items: center; padding: 24rpx; border-bottom: 1rpx solid #F0ECE6; gap: 16rpx; }
.field:last-child { border-bottom: none; }
.f-label { width: 80rpx; font-size: 26rpx; color: #8B7961; flex-shrink: 0; }
.f-input { flex: 1; font-size: 28rpx; color: #3A332D; height: 80rpx; line-height: 80rpx; }
.toggle-field { justify-content: space-between; }
.toggle { width: 80rpx; height: 44rpx; background: #D2C8BB; border-radius: 22rpx; position: relative; }
.toggle.on { background: #3A332D; }
.toggle-ball { width: 36rpx; height: 36rpx; background: #FFFFFF; border-radius: 50%; position: absolute; top: 4rpx; left: 4rpx; }
.toggle.on .toggle-ball { left: 40rpx; }

/* 多图选择网格 */
.img-grid { display: flex; flex-wrap: wrap; gap: 16rpx; }
.img-thumb { width: 160rpx; height: 160rpx; border-radius: 16rpx; overflow: hidden; position: relative; background: #EAE6E0; }
.thumb-img { width: 160rpx; height: 160rpx; display: block; }
.thumb-del {
  position: absolute; top: 6rpx; right: 6rpx;
  width: 40rpx; height: 40rpx; background: rgba(58,51,45,0.6);
  border-radius: 50%; display: flex; align-items: center; justify-content: center;
  font-size: 22rpx; color: #FFFFFF; line-height: 1;
}
.thumb-cover {
  position: absolute; bottom: 0; left: 0; right: 0;
  background: rgba(58,51,45,0.55); padding: 6rpx 0; text-align: center;
}
.cover-label { font-size: 20rpx; color: #FFFFFF; }
.img-add {
  width: 160rpx; height: 160rpx; background: #FFFFFF;
  border-radius: 16rpx; display: flex; flex-direction: column;
  align-items: center; justify-content: center; gap: 8rpx;
  border: 2rpx dashed #D2C8BB;
}
.add-icon { font-size: 52rpx; color: #C0B8AE; line-height: 1; }
.add-tip { font-size: 22rpx; color: #C0B8AE; }

/* 商品详情描述 */
.desc-wrap { background: #FFFFFF; border-radius: 20rpx; padding: 24rpx; }
.desc-input { width: 100%; min-height: 200rpx; font-size: 28rpx; color: #3A332D; line-height: 1.7; }

/* ── SKU 规格编辑 ── */
.sku-section-hd { display: flex; align-items: center; justify-content: space-between; margin-bottom: 12rpx; }
.sku-add-btn { font-size: 26rpx; color: #C87941; padding: 12rpx 28rpx; border: 1rpx solid #C87941; border-radius: 24rpx; }
.sku-group-edit { background: #FFFFFF; border-radius: 16rpx; padding: 24rpx; margin-bottom: 16rpx; }
.sku-group-row { display: flex; align-items: center; gap: 12rpx; margin-bottom: 16rpx; }
.sku-name-input { flex: 1; font-size: 28rpx; color: #3A332D; font-weight: 500; border-bottom: 2rpx solid #EDE5D8; padding-bottom: 12rpx; height: 72rpx; line-height: 72rpx; }
.sku-del-btn { font-size: 30rpx; color: #C0B8AE; padding: 10rpx; }
.sku-vals-input { width: 100%; font-size: 28rpx; color: #6B4F35; background: #F8F4F0; border-radius: 12rpx; padding: 18rpx 20rpx; box-sizing: border-box; min-height: 80rpx; line-height: 1.6; }
.sku-chips-preview { display: flex; flex-wrap: wrap; gap: 12rpx; margin-top: 16rpx; }
.sku-chip-preview { font-size: 24rpx; color: #5A4535; background: #F0ECE6; border-radius: 28rpx; padding: 8rpx 20rpx; border: 1rpx solid #EDE5D8; }
.sku-empty-hint { background: #FFFFFF; border-radius: 16rpx; padding: 28rpx; text-align: center; }
.sku-empty-text { font-size: 26rpx; color: #C0B8AE; }

/* 保存按钮 */
.save-btn {
  margin: 32rpx 24rpx 0;
  background: #3A332D; color: #F6F3EF;
  border-radius: 48rpx; font-size: 32rpx; font-weight: 500;
  padding: 28rpx 0; text-align: center; border: none; line-height: 1;
  width: calc(100% - 48rpx);
}
.save-btn::after { border: none; }
