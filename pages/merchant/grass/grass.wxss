page { background: #F5EFE6; }
.page { background: #F5EFE6; min-height: 100vh; }

.page-hd {
  display: flex; align-items: center; justify-content: space-between;
  padding: 32rpx 32rpx 20rpx;
}
.page-title { font-size: 34rpx; font-weight: 700; color: #2C1A0E; }
.add-btn {
  background: #2C1A0E; color: #F5EFE6;
  font-size: 26rpx; padding: 14rpx 28rpx; border-radius: 30rpx;
}

.empty-state { display: flex; flex-direction: column; align-items: center; padding: 120rpx 0; gap: 16rpx; }
.empty-icon { font-size: 80rpx; opacity: 0.4; }
.empty-text { font-size: 28rpx; color: #9C8672; }

.post-list { padding: 0 24rpx; }
.post-card {
  background: #FFFFFF; border-radius: 20rpx;
  margin-bottom: 20rpx; display: flex; gap: 20rpx;
  overflow: hidden; box-shadow: 0 2rpx 8rpx rgba(44,26,14,0.06);
}
.post-thumb { width: 160rpx; height: 160rpx; flex-shrink: 0; }
.post-body { flex: 1; padding: 20rpx 20rpx 20rpx 0; display: flex; flex-direction: column; justify-content: space-between; min-width: 0; }
.post-user { font-size: 24rpx; color: #C87941; display: block; margin-bottom: 8rpx; }
.post-title-text { font-size: 26rpx; color: #2C1A0E; font-weight: 500; display: block; line-height: 1.5; flex: 1; }
.post-actions { display: flex; align-items: center; gap: 12rpx; flex-wrap: wrap; margin-top: 12rpx; }
.act-badge { font-size: 22rpx; padding: 6rpx 16rpx; border-radius: 20rpx; }
.act-on { color: #5D9C5A; background: #EDF6EC; }
.act-off { color: #9C8672; background: #F0ECE6; }
.act-btn { font-size: 22rpx; padding: 6rpx 16rpx; border-radius: 20rpx; }
.act-edit { color: #5A4535; background: #F0ECE6; }
.act-del { color: #C87941; background: #FEF3EA; }
