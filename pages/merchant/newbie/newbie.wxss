.page { background: #F0ECE6; min-height: 100vh; }

.toolbar {
  display: flex; align-items: center; justify-content: space-between;
  padding: 20rpx 24rpx; background: #FFFFFF;
  border-bottom: 1rpx solid #EAE6E0;
}
.tool-count { font-size: 26rpx; color: #8B7961; }
.add-btn {
  background: #3A332D; color: #F6F3EF;
  font-size: 24rpx; padding: 14rpx 28rpx; border-radius: 32rpx;
}

.prod-scroll { height: calc(100vh - 96rpx); }
.prod-list { padding: 16rpx 24rpx; }

.prod-card {
  background: #FFFFFF; border-radius: 20rpx; margin-bottom: 16rpx;
  overflow: hidden; box-shadow: 0 2rpx 12rpx rgba(58,51,45,0.06);
  display: flex; gap: 18rpx; padding: 20rpx; align-items: flex-start;
}
.prod-img {
  width: 120rpx; height: 120rpx; border-radius: 14rpx;
  background: #EAE6E0; flex-shrink: 0;
}
.prod-info { flex: 1; min-width: 0; }
.prod-name {
  font-size: 28rpx; color: #3A332D; display: block;
  margin-bottom: 6rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; font-weight: 500;
}
.prod-desc {
  font-size: 22rpx; color: #B0A090; display: block; margin-bottom: 10rpx;
  overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
}
.prod-meta { display: flex; gap: 14rpx; align-items: center; flex-wrap: wrap; }
.prod-price { font-size: 28rpx; color: #C87941; font-weight: 700; }
.prod-origin { font-size: 22rpx; color: #C0B8AE; text-decoration: line-through; }
.prod-stock { font-size: 22rpx; color: #8B7961; }

.prod-right {
  display: flex; flex-direction: column; align-items: flex-end;
  gap: 12rpx; flex-shrink: 0;
}
.status-toggle {
  font-size: 22rpx; padding: 8rpx 18rpx; border-radius: 20rpx;
  font-weight: 500;
}
.status-toggle.on { background: #E8F5E9; color: #4CAF50; }
.status-toggle.off { background: #F5E8E0; color: #C87941; }

.prod-actions { display: flex; gap: 10rpx; }
.act-btn {
  font-size: 22rpx; padding: 10rpx 18rpx; border-radius: 12rpx; text-align: center;
}
.act-btn.edit { background: #3A332D; color: #F6F3EF; }
.act-btn.del { background: #F5E8E0; color: #C87941; }

/* 空态 */
.empty-state {
  display: flex; flex-direction: column; align-items: center;
  justify-content: center; padding: 120rpx 32rpx;
}
.empty-icon { font-size: 100rpx; margin-bottom: 24rpx; opacity: 0.4; }
.empty-text { font-size: 28rpx; color: #8B7961; margin-bottom: 36rpx; }
.empty-add-btn {
  background: #3A332D; color: #F6F3EF; font-size: 28rpx;
  padding: 22rpx 64rpx; border-radius: 48rpx;
}

/* 弹窗 */
.modal-mask {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.45); z-index: 100;
  display: flex; align-items: flex-end;
}
.modal-box {
  width: 100%; background: #FFFFFF; border-radius: 32rpx 32rpx 0 0;
  padding: 40rpx 32rpx 60rpx; max-height: 85vh; overflow-y: auto;
}
.modal-title {
  font-size: 34rpx; font-weight: 700; color: #3A332D;
  display: block; margin-bottom: 36rpx; text-align: center;
}

.form-item { margin-bottom: 24rpx; }
.form-label {
  font-size: 26rpx; color: #8B7961; display: block; margin-bottom: 10rpx;
}
.form-input {
  width: 100%; background: #F5F1EC; border-radius: 16rpx;
  padding: 22rpx 24rpx; font-size: 28rpx; color: #3A332D;
  box-sizing: border-box; height: 80rpx; line-height: 80rpx;
}

.modal-preview {
  margin: 16rpx 0 24rpx;
  display: flex; justify-content: center;
}
.preview-img {
  width: 160rpx; height: 160rpx; border-radius: 16rpx; background: #EAE6E0;
}

.modal-actions { display: flex; gap: 20rpx; margin-top: 32rpx; }
.modal-btn {
  flex: 1; text-align: center; padding: 28rpx 0;
  border-radius: 48rpx; font-size: 30rpx; font-weight: 500;
}
.modal-btn.cancel { background: #F0ECE6; color: #8B7961; }
.modal-btn.confirm { background: #3A332D; color: #F6F3EF; }
