<view class="page">
  <view class="toolbar">
    <text class="tool-count">共 {{products.length}} 件新人商品</text>
    <view class="add-btn" bindtap="onAdd">+ 添加商品</view>
  </view>

  <scroll-view scroll-y class="prod-scroll">
    <view wx:if="{{products.length === 0}}" class="empty-state">
      <text class="empty-icon">🎁</text>
      <text class="empty-text">暂无新人专享商品</text>
      <view class="empty-add-btn" bindtap="onAdd">立即添加</view>
    </view>

    <view class="prod-list" wx:else>
      <view class="prod-card" wx:for="{{products}}" wx:key="id">
        <image src="{{item.image}}" mode="aspectFill" class="prod-img" />
        <view class="prod-info">
          <text class="prod-name">{{item.name}}</text>
          <text class="prod-desc">{{item.desc}}</text>
          <view class="prod-meta">
            <text class="prod-price">¥{{item.price}}</text>
            <text class="prod-origin">原¥{{item.originalPrice}}</text>
            <text class="prod-stock">库存 {{item.stock}}</text>
          </view>
        </view>
        <view class="prod-right">
          <view class="status-toggle {{item.isActive ? 'on' : 'off'}}" catchtap="onToggleActive" data-id="{{item.id}}">
            {{item.isActive ? '上架' : '下架'}}
          </view>
          <view class="prod-actions">
            <view class="act-btn edit" catchtap="onEdit" data-id="{{item.id}}">编辑</view>
            <view class="act-btn del" catchtap="onDelete" data-id="{{item.id}}" data-name="{{item.name}}">删除</view>
          </view>
        </view>
      </view>
    </view>

    <view style="height:40rpx;"></view>
  </scroll-view>
</view>
