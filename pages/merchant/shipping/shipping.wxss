page { background: #F5EFE6; }

.page { min-height: 100vh; }

.scroll { height: 100vh; padding: 24rpx 28rpx; box-sizing: border-box; }

.tip-card {
  background: #FFF8F0;
  border: 1rpx solid #F0D9B5;
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
  margin-bottom: 24rpx;
}
.tip-icon { font-size: 28rpx; flex-shrink: 0; margin-top: 2rpx; }
.tip-text { font-size: 24rpx; color: #8B6914; line-height: 1.6; }

.section-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.section-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #2C1A0E;
  margin-bottom: 24rpx;
}

.field-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.field-label {
  font-size: 28rpx;
  color: #5A4535;
  flex-shrink: 0;
}

.field-input-wrap {
  display: flex;
  align-items: center;
  background: #F5EFE6;
  border-radius: 12rpx;
  padding: 0 20rpx;
  flex: 1;
  max-width: 260rpx;
  height: 80rpx;
}

.field-prefix {
  font-size: 28rpx;
  color: #C87941;
  font-weight: 600;
  margin-right: 8rpx;
  flex-shrink: 0;
}

.field-input {
  flex: 1;
  font-size: 28rpx;
  color: #2C1A0E;
  height: 80rpx;
  line-height: 80rpx;
  background: transparent;
}

.field-hint {
  display: block;
  font-size: 22rpx;
  color: #B0A898;
  margin-top: 16rpx;
  line-height: 1.5;
}

.preview-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
}

.preview-title {
  display: block;
  font-size: 24rpx;
  color: #9C8672;
  margin-bottom: 16rpx;
}

.preview-bar {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: #F5EFE6;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
}

.preview-icon { font-size: 30rpx; }

.preview-text { font-size: 26rpx; color: #5A4535; }

.save-btn {
  width: 100%;
  height: 96rpx;
  background: #2C1A0E;
  color: #F6F3EF;
  border-radius: 48rpx;
  font-size: 30rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}
