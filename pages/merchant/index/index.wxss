.page { background: #F0ECE6; min-height: 100vh; }
.merchant-scroll { height: 100vh; }

/* 头部 */
.m-header {
  display: flex; align-items: center; justify-content: space-between;
  background: #3A332D; padding: 40rpx 32rpx;
}
.m-brand { display: flex; align-items: center; gap: 20rpx; }
.m-logo { font-size: 56rpx; }
.m-title { font-size: 30rpx; font-weight: 600; color: #F6F3EF; display: block; margin-bottom: 8rpx; }
.m-role-row { display: flex; align-items: center; gap: 12rpx; }
.m-role-badge {
  font-size: 20rpx; padding: 4rpx 14rpx; border-radius: 12rpx;
  font-weight: 600; display: inline-block;
}
.m-role-badge.main { background: rgba(200,121,65,0.25); color: #F5C88A; }
.m-role-badge.sub { background: rgba(255,255,255,0.15); color: #C8C0B4; }
.m-sub { font-size: 22rpx; color: #8B7961; }
.logout-btn { color: #EAE6E0; font-size: 26rpx; border: 1rpx solid #8B7961; padding: 10rpx 24rpx; border-radius: 24rpx; }

/* 统计 */
.stats-grid { display: grid; grid-template-columns: repeat(2,1fr); gap: 20rpx; padding: 24rpx 24rpx 0; }
.stat-card {
  background: #FFFFFF; border-radius: 20rpx; padding: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(58,51,45,0.06);
  display: flex; flex-direction: column; align-items: center;
}
.stat-card.highlight { background: #3A332D; }
.stat-card.highlight .stat-num, .stat-card.highlight .stat-label { color: #F6F3EF; }
.stat-num { font-size: 44rpx; font-weight: 700; color: #3A332D; margin-bottom: 8rpx; display: block; }
.stat-label { font-size: 24rpx; color: #8B7961; display: block; }

/* 功能区 */
.menu-section { padding: 28rpx 24rpx 0; }
.menu-section-title { font-size: 26rpx; color: #8B7961; display: block; margin-bottom: 16rpx; }
.menu-cards { display: grid; grid-template-columns: repeat(2,1fr); gap: 16rpx; }
.menu-card {
  background: #FFFFFF; border-radius: 20rpx; padding: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(58,51,45,0.06);
  display: flex; flex-direction: column; gap: 8rpx;
}
.menu-card.full { grid-column: span 2; flex-direction: row; align-items: center; }
.menu-card.full .menu-card-right { flex: 1; }
.menu-card-icon { font-size: 52rpx; }
.menu-card-label { font-size: 28rpx; font-weight: 600; color: #3A332D; display: block; }
.menu-card-desc { font-size: 22rpx; color: #8B7961; display: block; }
.badge {
  background: #C87941; color: #FFFFFF; font-size: 22rpx;
  min-width: 40rpx; height: 40rpx; border-radius: 20rpx;
  text-align: center; line-height: 40rpx; padding: 0 10rpx;
}
.arrow { font-size: 36rpx; color: #C0B8AE; }
.log-badge {
  background: #3A332D; color: #F6F3EF; font-size: 22rpx;
  min-width: 48rpx; height: 40rpx; border-radius: 20rpx;
  text-align: center; line-height: 40rpx; padding: 0 12rpx;
}

/* 登录页 */
.login-page {
  min-height: 100vh; background: #F6F3EF;
  display: flex; flex-direction: column; align-items: center;
  padding: 80rpx 48rpx;
}
.login-header { text-align: center; margin-bottom: 60rpx; }
.login-icon { font-size: 100rpx; display: block; margin-bottom: 24rpx; }
.login-title { font-size: 40rpx; font-weight: 700; color: #3A332D; display: block; margin-bottom: 10rpx; }
.login-sub { font-size: 26rpx; color: #8B7961; display: block; }
.login-form { width: 100%; background: #FFFFFF; border-radius: 24rpx; overflow: hidden; margin-bottom: 20rpx; }
.login-field { display: flex; align-items: center; padding: 28rpx; border-bottom: 1rpx solid #F0ECE6; gap: 16rpx; }
.login-field:last-child { border-bottom: none; }
.lf-label { width: 80rpx; font-size: 28rpx; color: #8B7961; }
.lf-input { flex: 1; font-size: 28rpx; color: #3A332D; height: 80rpx; line-height: 80rpx; }
.login-tip { font-size: 24rpx; color: #C0B8AE; margin-bottom: 32rpx; }
.login-btn {
  width: 100%; background: #3A332D; color: #F6F3EF;
  border-radius: 48rpx; font-size: 32rpx; font-weight: 500;
  padding: 28rpx 0; text-align: center; border: none; line-height: 1;
  margin-bottom: 24rpx;
}
.login-btn::after { border: none; }
.login-btn.loading { background: #8B7961; }
.back-btn { font-size: 28rpx; color: #8B7961; padding: 20rpx; }
