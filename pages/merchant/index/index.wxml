<!-- 商家已登录 -->
<view class="page" wx:if="{{isMerchant}}">
  <scroll-view scroll-y class="merchant-scroll">
    <!-- 头部 -->
    <view class="m-header">
      <view class="m-brand">
        <text class="m-logo">🏪</text>
        <view>
          <text class="m-title">Petit Aura 商家后台</text>
          <view class="m-role-row">
            <view class="m-role-badge {{isMainAccount ? 'main' : 'sub'}}">
              <text class="m-role-text">{{isMainAccount ? '主账号' : '子账号'}}</text>
            </view>
            <text class="m-sub">{{merchantName}}</text>
          </view>
        </view>
      </view>
      <view class="logout-btn" bindtap="onLogout">退出</view>
    </view>

    <!-- 数据统计 -->
    <view class="stats-grid">
      <view class="stat-card">
        <text class="stat-num">{{stats.products}}</text>
        <text class="stat-label">在售商品</text>
      </view>
      <view class="stat-card">
        <text class="stat-num">{{stats.orders}}</text>
        <text class="stat-label">累计订单</text>
      </view>
      <view class="stat-card highlight">
        <text class="stat-num">{{stats.pendingOrders}}</text>
        <text class="stat-label">待发货</text>
      </view>
      <view class="stat-card" wx:if="{{isMainAccount}}">
        <text class="stat-num">¥{{stats.revenue}}</text>
        <text class="stat-label">累计营收</text>
      </view>
    </view>

    <!-- 商品管理 -->
    <view class="menu-section">
      <text class="menu-section-title">商品管理</text>
      <view class="menu-cards">
        <view class="menu-card full" bindtap="onManageProducts">
          <text class="menu-card-icon">📦</text>
          <view class="menu-card-right">
            <text class="menu-card-label">商品列表</text>
            <text class="menu-card-desc">查看/编辑商品，修改已售数量</text>
          </view>
          <text class="arrow">›</text>
        </view>
        <view class="menu-card full" bindtap="onAddProduct" wx:if="{{isMainAccount}}">
          <text class="menu-card-icon">➕</text>
          <view class="menu-card-right">
            <text class="menu-card-label">添加商品</text>
            <text class="menu-card-desc">发布新商品</text>
          </view>
          <text class="arrow">›</text>
        </view>
        <view class="menu-card full" bindtap="onManageNewbie" wx:if="{{isMainAccount}}">
          <text class="menu-card-icon">🎁</text>
          <view class="menu-card-right">
            <text class="menu-card-label">新人专享商品</text>
            <text class="menu-card-desc">编辑新人超值好物，设置专属价格</text>
          </view>
          <text class="arrow">›</text>
        </view>
      </view>
    </view>

    <!-- 订单管理 -->
    <view class="menu-section">
      <text class="menu-section-title">订单管理</text>
      <view class="menu-cards">
        <view class="menu-card full" bindtap="onManageOrders">
          <text class="menu-card-icon">📋</text>
          <view class="menu-card-right">
            <text class="menu-card-label">订单列表</text>
            <text class="menu-card-desc">查看订单状态、处理发货</text>
          </view>
          <text class="badge" wx:if="{{stats.pendingOrders > 0}}">{{stats.pendingOrders}}</text>
        </view>
      </view>
    </view>

    <!-- 子账号管理 + 操作日志（仅主账号可见） -->
    <view class="menu-section" wx:if="{{isMainAccount}}">
      <text class="menu-section-title">账号管理</text>
      <view class="menu-cards">
        <view class="menu-card full" bindtap="onManageAccounts">
          <text class="menu-card-icon">👥</text>
          <view class="menu-card-right">
            <text class="menu-card-label">子账号管理</text>
            <text class="menu-card-desc">添加/冻结子账号（当前 {{stats.subAccounts}} 个子账号）</text>
          </view>
          <text class="arrow">›</text>
        </view>
        <view class="menu-card full" bindtap="onManageLogs">
          <text class="menu-card-icon">📋</text>
          <view class="menu-card-right">
            <text class="menu-card-label">操作日志</text>
            <text class="menu-card-desc">查看所有销量/库存变动记录，可按类型筛选</text>
          </view>
          <text class="log-badge" wx:if="{{stats.logCount > 0}}">{{stats.logCount}}</text>
          <text class="arrow" wx:else>›</text>
        </view>
      </view>
    </view>

    <!-- 内容运营（主账号） -->
    <view class="menu-section" wx:if="{{isMainAccount}}">
      <text class="menu-section-title">内容运营</text>
      <view class="menu-cards">
        <view class="menu-card full" bindtap="onManageGrass">
          <text class="menu-card-icon">✨</text>
          <view class="menu-card-right">
            <text class="menu-card-label">大家都在做</text>
            <text class="menu-card-desc">管理首页种草卡片内容</text>
          </view>
          <text class="arrow">›</text>
        </view>
        <view class="menu-card full" bindtap="onManageReviews">
          <text class="menu-card-icon">⭐</text>
          <view class="menu-card-right">
            <text class="menu-card-label">精选评论管理</text>
            <text class="menu-card-desc">查看、添加、设置商品精选评论</text>
          </view>
          <text class="arrow">›</text>
        </view>
      </view>
    </view>

    <!-- 首页广告（主账号） -->
    <view class="menu-section" wx:if="{{isMainAccount}}">
      <text class="menu-section-title">首页广告</text>
      <view class="menu-cards">
        <view class="menu-card full" bindtap="onManageBanners">
          <text class="menu-card-icon">🖼️</text>
          <view class="menu-card-right">
            <text class="menu-card-label">管理首页广告</text>
            <text class="menu-card-desc">编辑轮播广告内容与图片</text>
          </view>
          <text class="arrow">›</text>
        </view>
      </view>
    </view>

    <!-- 运费管理（主账号） -->
    <view class="menu-section" wx:if="{{isMainAccount}}">
      <text class="menu-section-title">运费管理</text>
      <view class="menu-cards">
        <view class="menu-card full" bindtap="onManageShipping">
          <text class="menu-card-icon">🚚</text>
          <view class="menu-card-right">
            <text class="menu-card-label">运费设置</text>
            <text class="menu-card-desc">设置基础运费与满额免运费门槛</text>
          </view>
          <text class="arrow">›</text>
        </view>
      </view>
    </view>

    <!-- 营销工具（主账号） -->
    <view class="menu-section" wx:if="{{isMainAccount}}">
      <text class="menu-section-title">营销工具</text>
      <view class="menu-cards">
        <view class="menu-card full" bindtap="onManageCoupons">
          <text class="menu-card-icon">🎫</text>
          <view class="menu-card-right">
            <text class="menu-card-label">优惠券管理</text>
            <text class="menu-card-desc">创建、发放与管理优惠券</text>
          </view>
          <text class="arrow">›</text>
        </view>
      </view>
    </view>

    <!-- 定制管理（主账号） -->
    <view class="menu-section" wx:if="{{isMainAccount}}">
      <text class="menu-section-title">定制管理</text>
      <view class="menu-cards">
        <view class="menu-card full" bindtap="onManageCustomRequests">
          <text class="menu-card-icon">✏️</text>
          <view class="menu-card-right">
            <text class="menu-card-label">定制需求列表</text>
            <text class="menu-card-desc">查看顾客定制需求与联系方式</text>
          </view>
          <text class="badge" wx:if="{{stats.pendingCustom > 0}}">{{stats.pendingCustom}}</text>
          <text class="arrow" wx:else>›</text>
        </view>
        <view class="menu-card full" bindtap="onManageCases">
          <text class="menu-card-icon">🖼️</text>
          <view class="menu-card-right">
            <text class="menu-card-label">参考案例管理</text>
            <text class="menu-card-desc">上传案例供顾客定制时参考</text>
          </view>
          <text class="arrow">›</text>
        </view>
      </view>
    </view>

    <!-- 客服设置 -->
    <view class="menu-section" wx:if="{{isMainAccount}}">
      <text class="menu-section-title">客服设置</text>
      <view class="menu-cards">
        <view class="menu-card full" bindtap="onManageService">
          <text class="menu-card-icon">🎧</text>
          <view class="menu-card-right">
            <text class="menu-card-label">客服配置</text>
            <text class="menu-card-desc">设置客服微信号与二维码</text>
          </view>
          <text class="arrow">›</text>
        </view>
      </view>
    </view>

    <view style="height:60rpx;"></view>
  </scroll-view>
</view>

<!-- 商家登录 -->
<view class="login-page" wx:else>
  <view class="login-header">
    <text class="login-icon">🏪</text>
    <text class="login-title">商家登录</text>
    <text class="login-sub">仅限授权商家访问</text>
  </view>

  <view class="login-form">
    <view class="login-field">
      <text class="lf-label">账　号</text>
      <input class="lf-input" placeholder="商家账号" value="{{username}}" bindinput="onUsernameInput" />
    </view>
    <view class="login-field">
      <text class="lf-label">密　码</text>
      <input class="lf-input" password placeholder="商家密码" value="{{password}}" bindinput="onPasswordInput" />
    </view>
  </view>

  <view class="login-tip">主账号：admin / admin123</view>

  <button class="login-btn {{isLoading ? 'loading' : ''}}" bindtap="onLogin" disabled="{{isLoading}}">
    {{isLoading ? '验证中...' : '登录商家后台'}}
  </button>

  <view class="back-btn" bindtap="onBack">返回首页</view>
</view>
