page { background: #F5EFE6; }

.page {
  background: #F5EFE6;
  min-height: 100vh;
  padding: 24rpx 24rpx 40rpx;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-icon { font-size: 80rpx; margin-bottom: 20rpx; }
.empty-text { font-size: 30rpx; color: #6B4F35; font-weight: 500; }
.empty-sub { font-size: 24rpx; color: #9C8672; margin-top: 10rpx; margin-bottom: 32rpx; }

.empty-btn {
  background: #2C1A0E;
  color: #F5EFE6;
  font-size: 28rpx;
  padding: 18rpx 48rpx;
  border-radius: 40rpx;
}

.req-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(44,26,14,0.07);
}

.card-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18rpx;
  padding-bottom: 14rpx;
  border-bottom: 1rpx solid #F0EBE0;
}

.req-id-text {
  font-size: 20rpx;
  color: #9C8672;
  font-family: monospace;
}

.status-pill {
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
}

.status-pill.pending { background: #FFF3E0; color: #C87341; }
.status-pill.processing { background: #E8F4FD; color: #2196F3; }
.status-pill.completed { background: #E8F5E9; color: #4CAF50; }

.meta-row {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.meta-label {
  font-size: 22rpx;
  color: #9C8672;
  flex-shrink: 0;
  width: 120rpx;
}

.meta-val {
  font-size: 26rpx;
  color: #2C1A0E;
  flex: 1;
}

.desc-row {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.desc-text {
  font-size: 26rpx;
  color: #6B4F35;
  flex: 1;
  line-height: 1.6;
}

.img-section {
  margin-bottom: 12rpx;
}

.img-scroll {
  white-space: nowrap;
  width: 100%;
  margin-top: 8rpx;
}

.thumb-img {
  width: 120rpx;
  height: 120rpx;
  border-radius: 10rpx;
  margin-right: 10rpx;
  display: inline-block;
  object-fit: cover;
}

/* 商家回复气泡 */
.reply-area {
  margin-top: 16rpx;
  background: #F0F4FF;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  border-left: 4rpx solid #6B8FD4;
}

.reply-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 10rpx;
}

.reply-from {
  font-size: 22rpx;
  color: #4A6FAD;
  font-weight: 600;
}

.reply-time {
  font-size: 20rpx;
  color: #9AAACF;
}

.reply-text {
  font-size: 26rpx;
  color: #2C3F6B;
  line-height: 1.6;
  display: block;
}

.no-reply-area {
  margin-top: 14rpx;
  padding: 14rpx 0 4rpx;
  border-top: 1rpx solid #F0EBE0;
}

.no-reply-text {
  font-size: 22rpx;
  color: #C0B8AE;
}
